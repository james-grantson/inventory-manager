datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id          String   @id @default(uuid())
  name        String
  sku         String   @unique
  description String?
  category    String
  price       Float
  cost        Float
  quantity    Int
  minstock    Int      @default(10) @map("minstock")
  supplier    String?
  location    String?
  image_url   String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("products")
}
